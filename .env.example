# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Flask UI adapter
BACKEND_API_URL=http://127.0.0.1:8000

# Backend runtime mode: auto | demo | trained
MODEL_RUNTIME_MODE=auto

# Trained checkpoint paths (auto mode will use available checkpoints if these files exist)
CLASSIFICATION_MODEL_PATH=ml/artifacts/classification_resnet50_balanced/best_classification_resnet50_balanced.pt
CLASSIFICATION_ENSEMBLE_PATHS=
SEGMENTATION_MODEL_PATH=ml/artifacts/segmentation/best_segmentation.pt
STAGE_MODEL_PATH=
STAGE_MODEL_NAME=resnet18
STAGE_CLASSES=Low-grade,High-grade
STAGE_PROXY_ENABLED=true
CLASSIFICATION_TEMPERATURE=1.0
CLASSIFICATION_PRIOR_WEIGHTS=Glioma=1.0,Meningioma=1.0,Pituitary=0.86,No_Tumor=1.08
ENABLE_TTA_INFERENCE=true

# Storage and database
DATABASE_URL=
DB_PATH=backend/storage/brain_mri.db
STORAGE_ROOT=backend/storage
UPLOAD_DIR=backend/storage/uploads
MASK_DIR=backend/storage/masks
GRADCAM_DIR=backend/storage/gradcam
OVERLAY_DIR=backend/storage/overlays
REPORT_DIR=backend/storage/reports
VECTOR_STORE_DIR=backend/storage/vector_store
VECTOR_DB_DIR=backend/storage/vector_store
VOLUME_PREVIEW_DIR=backend/storage/volumes
RAG_GUIDELINES_PATH=docs/WHO_CNS_TUMOR_GUIDELINES.md
INCLUDE_GUIDELINE_RAG=false

# Optional thresholds
LOW_CONFIDENCE_THRESHOLD=0.55
TUMOR_DETECTION_THRESHOLD=0.45
NO_TUMOR_PROBABILITY_THRESHOLD=0.56
MIN_TUMOR_AREA_RATIO=0.004
MIN_TUMOR_PIXELS=260
PITUITARY_GUARD_ENABLED=true
PITUITARY_GUARD_MARGIN=0.12
PITUITARY_AREA_RATIO_MAX=0.16
PITUITARY_CENTROID_X_MIN=0.28
PITUITARY_CENTROID_X_MAX=0.72
PITUITARY_CENTROID_Y_MIN=0.40
PITUITARY_CENTROID_Y_MAX=0.90
MC_DROPOUT_SAMPLES=10
MC_DROPOUT_RATE=0.35
XAI_METHOD=hirescam
NIFTI_MODALITY_INDEX=0
SKULL_STRIP_MODE=otsu
HD_BET_COMMAND=
